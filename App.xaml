<Application x:Class="BDP_MVVM.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:BDP_MVVM.Views.Converters"
             StartupUri="Views/LoginWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Подключаем стили -->
                <ResourceDictionary Source="Resources/Styles/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="Resources/Styles/TextBoxStyles.xaml"/>
                <ResourceDictionary Source="Resources/Styles/ListViewStyles.xaml"/>
                <ResourceDictionary Source="Resources/Styles/FormStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- Конвертеры -->
            <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
            <converters:StringToVisibilityConverter x:Key="StringToVis"/>
            <converters:NullToVisibilityConverter x:Key="NullToVis"/>
            <converters:NotNullToVisibilityConverter x:Key="NotNullToVis"/>
            <converters:DifficultyToColorConverter x:Key="DifficultyToColor"/>
            <converters:ReadinessToColorConverter x:Key="ReadinessToColor"/>
            <converters:ReadinessToTextConverter x:Key="ReadinessToText"/>
            <converters:InverseBooleanConverter x:Key="InverseBool"/>
            <converters:PercentToWidthConverter x:Key="PercentToWidth"/>
            <converters:RangeMarginConverter x:Key="RangeMarginConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>