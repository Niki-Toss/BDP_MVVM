<UserControl x:Class="BDP_MVVM.Views.PlatformsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:BDP_MVVM.Views.Converters"
             Background="#F5F5F5">
    <UserControl.Resources>
        <!-- Конвертеры для видимости элементов -->
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:NotNullToVisibilityConverter x:Key="NotNullToVis"/>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- ========== ЛЕВАЯ ПАНЕЛЬ: список платформ и форма создания ========== -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- Заголовок с иконкой и счётчиком -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="💻" FontSize="28" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Платформы"
                               FontSize="22" FontWeight="Bold" Foreground="#212121"/>
                    <TextBlock Text="{Binding Platforms.Count, StringFormat='Всего: {0}'}"
                               FontSize="13" Foreground="#666666"/>
                </StackPanel>
            </StackPanel>
            <!-- Форма добавления новой платформы -->
            <Border Grid.Row="1" Background="White" CornerRadius="8"
                    Padding="16" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Новая платформа"
                               FontWeight="SemiBold" FontSize="14"
                               Foreground="#212121" Margin="0,0,0,12"/>
                    <TextBlock Text="Название *" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding NewНазвание, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13" Height="36" Padding="10,0"
                             VerticalContentAlignment="Center"
                             Background="White" Foreground="#212121"
                             BorderBrush="#E0E0E0" BorderThickness="1"
                             Margin="0,0,0,12"/>
                    <!-- Флаг автопроверки готовности -->
                    <CheckBox Content="Есть автопроверка готовности"
                              IsChecked="{Binding NewАвто}"
                              FontSize="13"
                              Foreground="#212121"
                              Margin="0,0,0,14"/>
                    <Button Content="➕ Добавить платформу"
                            Command="{Binding AddCommand}"
                            Background="#4CAF50"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource ActionButton}"
                            Margin="0"/>
                </StackPanel>
            </Border>
            <!-- Список платформ -->
            <Border Grid.Row="2" Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <Grid>
                    <!-- Заглушка пустого списка -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding HasPlatforms, Converter={StaticResource InverseBoolToVis}}">
                        <TextBlock Text="💻" FontSize="48" HorizontalAlignment="Center" Opacity="0.3"/>
                        <TextBlock Text="Нет платформ" FontSize="16"
                                   Foreground="#9E9E9E"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                    <!-- ListView платформ -->
                    <ListView ItemsSource="{Binding Platforms}"
                              SelectedItem="{Binding SelectedPlatform}"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="8">
                        <!-- Стиль элемента списка с подсветкой -->
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,4"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="bg" Background="Transparent"
                                                    CornerRadius="6" Padding="12,10">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#E3F2FD"/>
                                                    <Setter TargetName="bg" Property="BorderBrush" Value="#2196F3"/>
                                                    <Setter TargetName="bg" Property="BorderThickness" Value="1"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#F5F5F5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <!-- Шаблон элемента: название, бейдж автопроверки, количество задач -->
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Название}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#212121"/>
                                        <TextBlock Text="{Binding АвтопроверкаТекст}"
                                                   FontSize="12" Foreground="#9E9E9E"/>
                                    </StackPanel>
                                    <!-- Бейдж автопроверки (зелёный/красный) -->
                                    <Border Grid.Column="1"
                                            CornerRadius="10"
                                            Padding="7,2"
                                            VerticalAlignment="Center"
                                            Margin="4,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Автопроверка_готовности}" Value="False">
                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="AUTO"/>
                                                    <Setter Property="Foreground" Value="#388E3C"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Автопроверка_готовности}" Value="False">
                                                            <Setter Property="Text" Value="ручная"/>
                                                            <Setter Property="Foreground" Value="#C62828"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <!-- Бейдж с количеством задач -->
                                    <Border Grid.Column="2"
                                            Background="#E3F2FD"
                                            CornerRadius="12"
                                            Padding="8,3"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding КоличествоЗадач}"
                                                   FontSize="12" FontWeight="Bold"
                                                   Foreground="#1565C0"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <!-- Индикатор загрузки -->
                    <Border Background="#EEFFFFFF"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ProgressBar Width="150" Height="4"
                                         IsIndeterminate="True" Margin="0,0,0,8"/>
                            <TextBlock Text="Загрузка..."
                                       Foreground="#666666" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        <!-- ========== ПРАВАЯ ПАНЕЛЬ: детали выбранной платформы ========== -->
        <Grid Grid.Column="1">
            <!-- Заглушка когда ничего не выбрано -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding SelectedPlatform, Converter={StaticResource NullToVis}}">
                <TextBlock Text="👈" FontSize="64" HorizontalAlignment="Center" Opacity="0.3"/>
                <TextBlock Text="Выберите платформу из списка"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="#9E9E9E"
                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
            <!-- Карточка с деталями платформы -->
            <Border Background="White" CornerRadius="8" Padding="24"
                    VerticalAlignment="Top"
                    Visibility="{Binding SelectedPlatform, Converter={StaticResource NotNullToVis}}">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Заголовок карточки -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="💻" FontSize="32" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedPlatform.Название}"
                                       FontSize="20" FontWeight="Bold" Foreground="#212121"/>
                            <TextBlock Text="{Binding SelectedPlatform.АвтопроверкаТекст}"
                                       FontSize="13" Foreground="#666666"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Статистика платформы -->
                    <Border Background="#F5F5F5" CornerRadius="8"
                            Padding="16" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Margin="0,0,40,0">
                                <TextBlock Text="ID платформы" FontSize="12" Foreground="#9E9E9E"/>
                                <TextBlock Text="{Binding SelectedPlatform.Platform_ID, StringFormat='#{0}'}"
                                           FontSize="20" FontWeight="Bold" Foreground="#2196F3"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,40,0">
                                <TextBlock Text="Задач" FontSize="12" Foreground="#9E9E9E"/>
                                <TextBlock Text="{Binding SelectedPlatform.КоличествоЗадач}"
                                           FontSize="20" FontWeight="Bold" Foreground="#4CAF50"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Автопроверка" FontSize="12" Foreground="#9E9E9E"/>
                                <TextBlock FontSize="20" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="✅ Да"/>
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedPlatform.Автопроверка_готовности}" Value="False">
                                                    <Setter Property="Text" Value="❌ Нет"/>
                                                    <Setter Property="Foreground" Value="#F44336"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <!-- Форма редактирования (показывается при нажатии "Редактировать") -->
                    <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Название *" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding EditНазвание, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" Height="36" Padding="10,0"
                                 VerticalContentAlignment="Center"
                                 Background="White" Foreground="#212121"
                                 BorderBrush="#2196F3" BorderThickness="2"
                                 Margin="0,0,0,12"/>
                        <CheckBox Content="Есть автопроверка готовности"
                                  IsChecked="{Binding EditАвто}"
                                  FontSize="13"
                                  Foreground="#212121"
                                  Margin="0,0,0,16"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾 Сохранить"
                                    Command="{Binding SaveEditCommand}"
                                    Background="#4CAF50"
                                    Style="{StaticResource ActionButton}"/>
                            <Button Content="✖ Отмена"
                                    Command="{Binding CancelEditCommand}"
                                    Background="#9E9E9E"
                                    Style="{StaticResource ActionButton}" Margin="0"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Кнопки действий (показываются когда не в режиме редактирования) -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
                        <Button Content="✏️ Редактировать"
                                Command="{Binding EditCommand}"
                                Background="#2196F3"
                                Style="{StaticResource ActionButton}"/>
                        <Button Content="🗑️ Удалить"
                                Command="{Binding DeleteCommand}"
                                Background="#F44336"
                                Style="{StaticResource ActionButton}" Margin="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>