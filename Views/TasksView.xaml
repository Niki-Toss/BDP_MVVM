<UserControl x:Class="BDP_MVVM.Views.TasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:BDP_MVVM.Views.Converters"
             Background="#F5F5F5">
    <UserControl.Resources>
        <!-- Конвертеры -->
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:ReadinessToTextConverter x:Key="ReadinessToText"/>
        <converters:DifficultyToColorConverter x:Key="DifficultyToColor"/>
        <converters:RangeMarginConverter x:Key="RangeMarginConverter"/>
        <!-- Стиль для двойного ползунка сложности (локальный, только для TasksView) -->
        <Style x:Key="RangeSliderStyle" TargetType="Slider">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <!-- Невидимая дорожка (только ползунок виден) -->
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" 
                                                  Background="Transparent" 
                                                  BorderThickness="0"
                                                  IsHitTestVisible="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" 
                                                  Background="Transparent" 
                                                  BorderThickness="0"
                                                  IsHitTestVisible="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="20" Height="20">
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Grid>
                                                    <!-- Расширенная область клика (невидимая, для удобства) -->
                                                    <Ellipse Width="32" Height="32" 
                                                             Fill="Transparent"
                                                             Cursor="Hand"/>
                                                    <!-- Видимый кружок ползунка -->
                                                    <Ellipse Width="20" Height="20"
                                                             Fill="{Binding Foreground, 
                                                                    RelativeSource={RelativeSource AncestorType=Slider}}"
                                                             Stroke="White" 
                                                             StrokeThickness="2"
                                                             Cursor="Hand">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect Color="#000000" Opacity="0.3" 
                                                                              BlurRadius="4" ShadowDepth="1"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Стиль кнопки действий в карточке задачи -->
        <Style x:Key="TaskActionButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- ========== Заголовок страницы ========== -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="📋" FontSize="28" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Задачи" FontSize="22" FontWeight="Bold" Foreground="#212121"/>
                <TextBlock Text="{Binding Tasks.Count, StringFormat='Всего: {0}'}"
                           FontSize="13" Foreground="#666666"/>
            </StackPanel>
        </StackPanel>
        <!-- ========== ПАНЕЛЬ ФИЛЬТРОВ ========== -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>
            <StackPanel>
                <!-- Заголовок и кнопка сброса -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🔍" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Фильтры" FontSize="16" FontWeight="Bold"
                                   Foreground="#212121" VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- Кнопка сброса всех фильтров -->
                    <Button Grid.Column="1" Content="✖ Сбросить фильтры"
                            Command="{Binding ClearFiltersCommand}"
                            Background="#9E9E9E" Foreground="White"
                            BorderThickness="0" Padding="10,6"
                            FontSize="12" Cursor="Hand"
                            HorizontalAlignment="Right">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                <!-- Сетка фильтров (Теги | Платформы | Контесты | Сложность) -->
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>
                    <!-- ========== ФИЛЬТР ТЕГОВ ========== -->
                    <Grid Grid.Column="0" Margin="0,0,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Теги" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555555" Margin="0,0,0,5"/>
                        <!-- Кнопка-дропдаун -->
                        <ToggleButton x:Name="TagsToggle" Grid.Row="1" Height="34"
                                      Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                      HorizontalContentAlignment="Left" Padding="10,0">
                            <ToggleButton.Content>
                                <Grid>
                                    <TextBlock Text="{Binding SelectedTagsText}" FontSize="13"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="▼" FontSize="10" HorizontalAlignment="Right"
                                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                                </Grid>
                            </ToggleButton.Content>
                        </ToggleButton>
                        <!-- Popup с чекбоксами тегов -->
                        <Popup IsOpen="{Binding IsChecked, ElementName=TagsToggle}"
                               PlacementTarget="{Binding ElementName=TagsToggle}"
                               Placement="Bottom" StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                    CornerRadius="4" MaxHeight="250" MinWidth="200">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="10" ShadowDepth="2"/>
                                </Border.Effect>
                                <StackPanel>
                                    <!-- Чекбокс "Без тега" -->
                                    <CheckBox Content="✖ Без тега" IsChecked="{Binding ShowWithoutTag}"
                                              FontWeight="Bold" Foreground="#F44336"
                                              Margin="12,8,12,4" FontSize="13"/>
                                    <Separator Margin="8,4"/>
                                    <!-- Список тегов -->
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                                        <ItemsControl ItemsSource="{Binding FilterTagItems}" Padding="8">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Name}"
                                                              IsChecked="{Binding IsSelected}"
                                                              Margin="4,2" FontSize="13"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <!-- ========== ФИЛЬТР ПЛАТФОРМ ========== -->
                    <Grid Grid.Column="1" Margin="0,0,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Платформы" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555555" Margin="0,0,0,5"/>
                        <ToggleButton x:Name="PlatformsToggle" Grid.Row="1" Height="34"
                                      Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                      HorizontalContentAlignment="Left" Padding="10,0">
                            <ToggleButton.Content>
                                <Grid>
                                    <TextBlock Text="{Binding SelectedPlatformsText}" FontSize="13"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="▼" FontSize="10" HorizontalAlignment="Right"
                                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                                </Grid>
                            </ToggleButton.Content>
                        </ToggleButton>
                        <Popup IsOpen="{Binding IsChecked, ElementName=PlatformsToggle}"
                               PlacementTarget="{Binding ElementName=PlatformsToggle}"
                               Placement="Bottom" StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                    CornerRadius="4" MaxHeight="250" MinWidth="200">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="10" ShadowDepth="2"/>
                                </Border.Effect>
                                <StackPanel>
                                    <CheckBox Content="✖ Без платформы" IsChecked="{Binding ShowWithoutPlatform}"
                                              FontWeight="Bold" Foreground="#F44336"
                                              Margin="12,8,12,4" FontSize="13"/>
                                    <Separator Margin="8,4"/>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                                        <ItemsControl ItemsSource="{Binding FilterPlatformItems}" Padding="8">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Name}"
                                                              IsChecked="{Binding IsSelected}"
                                                              Margin="4,2" FontSize="13"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <!-- ========== ФИЛЬТР КОНТЕСТОВ ========== -->
                    <Grid Grid.Column="2" Margin="0,0,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Контесты" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555555" Margin="0,0,0,5"/>
                        <ToggleButton x:Name="ContestsToggle" Grid.Row="1" Height="34"
                                      Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                      HorizontalContentAlignment="Left" Padding="10,0">
                            <ToggleButton.Content>
                                <Grid>
                                    <TextBlock Text="{Binding SelectedContestsText}" FontSize="13"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="▼" FontSize="10" HorizontalAlignment="Right"
                                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                                </Grid>
                            </ToggleButton.Content>
                        </ToggleButton>
                        <Popup IsOpen="{Binding IsChecked, ElementName=ContestsToggle}"
                               PlacementTarget="{Binding ElementName=ContestsToggle}"
                               Placement="Bottom" StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                    CornerRadius="4" MaxHeight="250" MinWidth="200">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="10" ShadowDepth="2"/>
                                </Border.Effect>
                                <StackPanel>
                                    <CheckBox Content="✖ Без контеста" IsChecked="{Binding ShowWithoutContest}"
                                              FontWeight="Bold" Foreground="#F44336"
                                              Margin="12,8,12,4" FontSize="13"/>
                                    <Separator Margin="8,4"/>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                                        <ItemsControl ItemsSource="{Binding FilterContestItems}" Padding="8">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Name}"
                                                              IsChecked="{Binding IsSelected}"
                                                              Margin="4,2" FontSize="13"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <!-- ========== ФИЛЬТР СЛОЖНОСТИ (двойной ползунок) ========== -->
                    <StackPanel Grid.Column="3">
                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,8">
                            <Run Text="Сложность: "/>
                            <Run Text="{Binding MinDifficulty, Mode=OneWay}"/>
                            <Run Text=" — "/>
                            <Run Text="{Binding MaxDifficulty, Mode=OneWay}"/>
                        </TextBlock>
                        <!-- Двойной ползунок (Range Slider) -->
                        <Grid Height="40" Margin="0,5,0,0">
                            <!-- Общая дорожка (серая полоса) -->
                            <Border Height="4" VerticalAlignment="Center"
                                    Background="#E0E0E0" CornerRadius="2" Margin="10,0"
                                    IsHitTestVisible="False"/>
                            <!-- Активная часть диапазона (синяя полоса между ползунками) -->
                            <Border Height="4" VerticalAlignment="Center"
                                    Background="#2196F3" CornerRadius="2"
                                    IsHitTestVisible="False">
                                <Border.Margin>
                                    <MultiBinding Converter="{StaticResource RangeMarginConverter}">
                                        <Binding Path="MinDifficulty"/>
                                        <Binding Path="MaxDifficulty"/>
                                        <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                    </MultiBinding>
                                </Border.Margin>
                            </Border>
                            <!-- Ползунок Max (оранжевый - рисуем сначала, чтобы был ниже) -->
                            <Slider Minimum="1" Maximum="10"
                                    Value="{Binding MaxDifficulty}"
                                    IsSnapToTickEnabled="True" TickFrequency="1"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource RangeSliderStyle}"
                                    Panel.ZIndex="1">
                                <Slider.Foreground>
                                    <SolidColorBrush Color="#FF9800"/>
                                </Slider.Foreground>
                            </Slider>
                            <!-- Ползунок Min (синий - рисуем потом, чтобы был выше) -->
                            <Slider Minimum="1" Maximum="10"
                                    Value="{Binding MinDifficulty}"
                                    IsSnapToTickEnabled="True" TickFrequency="1"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource RangeSliderStyle}"
                                    Panel.ZIndex="2">
                                <Slider.Foreground>
                                    <SolidColorBrush Color="#2196F3"/>
                                </Slider.Foreground>
                            </Slider>
                            <!-- Подписи значений (1 и 10) -->
                            <TextBlock Text="1" FontSize="10" Foreground="#9E9E9E"
                                       HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                       Margin="0,0,0,-18" IsHitTestVisible="False"/>
                            <TextBlock Text="10" FontSize="10" Foreground="#9E9E9E"
                                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                       Margin="0,0,0,-18" IsHitTestVisible="False"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
        <!-- ========== СПИСОК ЗАДАЧ ========== -->
        <Border Grid.Row="2" Background="White" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <!-- Заглушка пустого списка -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Tasks.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center" Opacity="0.3"/>
                    <TextBlock Text="Нет задач" FontSize="16" Foreground="#9E9E9E"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
                <!-- ListView с задачами (отфильтрованный) -->
                <ListView ItemsSource="{Binding TasksView.View}"
                          SelectedItem="{Binding SelectedTask}"
                          Background="Transparent" BorderThickness="0" Padding="8">
                    <!-- Стиль карточки задачи -->
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,8"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="bg" Background="White"
                                                CornerRadius="8" Padding="16"
                                                BorderThickness="1" BorderBrush="#E0E0E0">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="bg" Property="BorderBrush" Value="#2196F3"/>
                                                <Setter TargetName="bg" Property="Background" Value="#E3F2FD"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#F5F5F5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <!-- Шаблон карточки задачи -->
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>
                                <!-- ID задачи -->
                                <Border Grid.Column="0" Background="#E3F2FD"
                                        CornerRadius="6" Padding="8,4" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Task_ID, StringFormat='#{0}'}"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="#1565C0" HorizontalAlignment="Center"/>
                                </Border>
                                <!-- Название и метаданные (автор, дата) -->
                                <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Название}"
                                               FontSize="15" FontWeight="SemiBold" Foreground="#212121"
                                               TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding Автор.Логин, StringFormat='👤 {0}'}"
                                                   FontSize="11" Foreground="#9E9E9E" Margin="0,0,12,0"/>
                                        <TextBlock Text="{Binding ДатаСозданияФорматированная, StringFormat='📅 {0}'}"
                                                   FontSize="11" Foreground="#9E9E9E"/>
                                    </StackPanel>
                                </StackPanel>
                                <!-- Бейдж сложности (цвет зависит от уровня) -->
                                <Border Grid.Column="2" CornerRadius="6" Padding="10,4"
                                        Background="{Binding Сложность, Converter={StaticResource DifficultyToColor}}"
                                        VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding Сложность}"
                                               FontSize="13" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <!-- Бейдж готовности (зелёный/красный) -->
                                <Border Grid.Column="3" CornerRadius="6" Padding="8,4"
                                        VerticalAlignment="Center" Margin="0,0,8,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FFEBEE"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Готовность_Codeforces}" Value="True">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Готовность_Codeforces, Converter={StaticResource ReadinessToText}}"
                                               FontSize="12" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#C62828"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Готовность_Codeforces}" Value="True">
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <!-- Кнопки действий (просмотр, редактировать, удалить) -->
                                <StackPanel Grid.Column="4" Orientation="Horizontal"
                                            VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <!-- Просмотр -->
                                    <Button Content="👁️" ToolTip="Просмотр"
                                            Command="{Binding DataContext.ViewTaskCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="#607D8B"
                                            Margin="0,0,4,0"
                                            Style="{StaticResource TaskActionButton}"/>
                                    <!-- Редактировать -->
                                    <Button Content="✏️" ToolTip="Редактировать"
                                            Command="{Binding DataContext.EditTaskCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="#2196F3"
                                            Margin="0,0,4,0"
                                            Style="{StaticResource TaskActionButton}"/>
                                    <!-- Удалить -->
                                    <Button Content="🗑️" ToolTip="Удалить"
                                            Command="{Binding DataContext.DeleteTaskCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="#F44336"
                                            Style="{StaticResource TaskActionButton}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <!-- Индикатор загрузки -->
                <Border Background="#EEFFFFFF"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar Width="150" Height="4" IsIndeterminate="True" Margin="0,0,0,8"/>
                        <TextBlock Text="Загрузка..." Foreground="#666666" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        <!-- ========== Плавающая кнопка "Добавить задачу" ========== -->
        <Button Grid.Row="2" Content="➕" ToolTip="Добавить задачу"
                Command="{Binding AddTaskCommand}"
                Background="#4CAF50" Foreground="White"
                Width="56" Height="56"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,20,20"
                BorderThickness="0"
                Cursor="Hand"
                FontSize="24">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="28">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" Opacity="0.3"
                                              BlurRadius="10" ShadowDepth="3"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>