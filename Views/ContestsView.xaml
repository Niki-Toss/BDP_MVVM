<UserControl x:Class="BDP_MVVM.Views.ContestsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:BDP_MVVM.Views.Converters"
             Background="#F5F5F5">
    <UserControl.Resources>
        <!-- Конвертеры для видимости элементов -->
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:NotNullToVisibilityConverter x:Key="NotNullToVis"/>
        <!-- Стиль кнопок действий (добавить, редактировать, удалить) -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Стили для форм -->
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="FormTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- ========== ЛЕВАЯ ПАНЕЛЬ: список контестов и форма создания ========== -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- Заголовок с иконкой и счётчиком -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="🏆" FontSize="28" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Контесты"
                               FontSize="22" FontWeight="Bold" Foreground="#212121"/>
                    <TextBlock Text="{Binding Contests.Count, StringFormat='Всего: {0}'}"
                               FontSize="13" Foreground="#666666"/>
                </StackPanel>
            </StackPanel>
            <!-- Форма добавления нового контеста -->
            <Border Grid.Row="1" Background="White" CornerRadius="8"
                    Padding="16" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Новый контест"
                               FontWeight="SemiBold" FontSize="14"
                               Foreground="#212121" Margin="0,0,0,12"/>
                    <TextBlock Text="Название *" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding NewНазвание, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}"/>
                    <TextBlock Text="Год проведения *" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding NewГод, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}"/>
                    <Button Content="➕ Добавить контест"
                            Command="{Binding AddCommand}"
                            Background="#4CAF50"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource ActionButton}"
                            Margin="0"/>
                </StackPanel>
            </Border>
            <!-- Список контестов с группировкой по годам -->
            <Border Grid.Row="2" Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <Grid>
                    <!-- Заглушка когда список пуст -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding HasContests, Converter={StaticResource InverseBoolToVis}}">
                        <TextBlock Text="🏆" FontSize="48"
                                   HorizontalAlignment="Center" Opacity="0.3"/>
                        <TextBlock Text="Нет контестов" FontSize="16"
                                   Foreground="#9E9E9E"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                    <!-- ListView с группировкой по годам -->
                    <ListView ItemsSource="{Binding ContestsView.View}"
                              SelectedItem="{Binding SelectedContest}"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="8">
                        <!-- Заголовки групп (года) -->
                        <ListView.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Background="#E3F2FD"
                                                CornerRadius="6"
                                                Padding="10,6"
                                                Margin="0,4,0,4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📅 " FontSize="13"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="14" FontWeight="Bold"
                                                           Foreground="#1565C0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ItemCount, StringFormat=' · {0} контестов'}"
                                                           FontSize="12" Foreground="#1976D2"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListView.GroupStyle>
                        <!-- Стиль элемента списка (подсветка при выборе и наведении) -->
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,4"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="bg" Background="Transparent"
                                                    CornerRadius="6" Padding="12,10">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#E8F5E9"/>
                                                    <Setter TargetName="bg" Property="BorderBrush" Value="#4CAF50"/>
                                                    <Setter TargetName="bg" Property="BorderThickness" Value="1"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#F5F5F5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <!-- Шаблон элемента: название, год и количество задач -->
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Название}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#212121" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Год_создания, StringFormat='Год: {0}'}"
                                                   FontSize="12" Foreground="#9E9E9E"/>
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Background="#E8F5E9"
                                            CornerRadius="12"
                                            Padding="8,3"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding КоличествоЗадач}"
                                                   FontSize="12" FontWeight="Bold"
                                                   Foreground="#388E3C"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <!-- Индикатор загрузки -->
                    <Border Background="#EEFFFFFF"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ProgressBar Width="150" Height="4"
                                         IsIndeterminate="True" Margin="0,0,0,8"/>
                            <TextBlock Text="Загрузка..."
                                       Foreground="#666666" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        <!-- ========== ПРАВАЯ ПАНЕЛЬ: детали выбранного контеста ========== -->
        <Grid Grid.Column="1">
            <!-- Заглушка когда ничего не выбрано -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding SelectedContest, Converter={StaticResource NullToVis}}">
                <TextBlock Text="👈" FontSize="64"
                           HorizontalAlignment="Center" Opacity="0.3"/>
                <TextBlock Text="Выберите контест из списка"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="#9E9E9E"
                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
            <!-- Карточка с деталями контеста -->
            <Border Background="White" CornerRadius="8" Padding="24"
                    VerticalAlignment="Top"
                    Visibility="{Binding SelectedContest, Converter={StaticResource NotNullToVis}}">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Заголовок карточки -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="🏆" FontSize="32"
                                   Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedContest.Название}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="#212121" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedContest.Год_создания, StringFormat='Год: {0}'}"
                                       FontSize="13" Foreground="#666666"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Статистика контеста -->
                    <Border Background="#F5F5F5" CornerRadius="8"
                            Padding="16" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Margin="0,0,40,0">
                                <TextBlock Text="ID контеста"
                                           FontSize="12" Foreground="#9E9E9E"/>
                                <TextBlock Text="{Binding SelectedContest.Contest_ID, StringFormat='#{0}'}"
                                           FontSize="20" FontWeight="Bold" Foreground="#4CAF50"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,40,0">
                                <TextBlock Text="Год" FontSize="12" Foreground="#9E9E9E"/>
                                <TextBlock Text="{Binding SelectedContest.Год_создания}"
                                           FontSize="20" FontWeight="Bold" Foreground="#FF9800"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Задач" FontSize="12" Foreground="#9E9E9E"/>
                                <TextBlock Text="{Binding SelectedContest.КоличествоЗадач}"
                                           FontSize="20" FontWeight="Bold" Foreground="#2196F3"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <!-- Форма редактирования (показывается при нажатии "Редактировать") -->
                    <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Название *" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding EditНазвание, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" Height="36" Padding="10,0"
                                 VerticalContentAlignment="Center"
                                 Background="White" Foreground="#212121"
                                 BorderBrush="#4CAF50" BorderThickness="2"
                                 Margin="0,0,0,12"/>
                        <TextBlock Text="Год проведения *" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding EditГод, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" Height="36" Padding="10,0"
                                 VerticalContentAlignment="Center"
                                 Background="White" Foreground="#212121"
                                 BorderBrush="#4CAF50" BorderThickness="2"
                                 Margin="0,0,0,16"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾 Сохранить"
                                    Command="{Binding SaveEditCommand}"
                                    Background="#4CAF50"
                                    Style="{StaticResource ActionButton}"/>
                            <Button Content="✖ Отмена"
                                    Command="{Binding CancelEditCommand}"
                                    Background="#9E9E9E"
                                    Style="{StaticResource ActionButton}" Margin="0"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Кнопки действий (показываются когда не в режиме редактирования) -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
                        <Button Content="✏️ Редактировать"
                                Command="{Binding EditCommand}"
                                Background="#2196F3"
                                Style="{StaticResource ActionButton}"/>
                        <Button Content="🗑️ Удалить"
                                Command="{Binding DeleteCommand}"
                                Background="#F44336"
                                Style="{StaticResource ActionButton}" Margin="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>