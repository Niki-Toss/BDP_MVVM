<Window x:Class="BDP_MVVM.Views.TaskEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:BDP_MVVM.Views.Converters"
        Title="{Binding WindowTitle}"
        Width="650" Height="650"
        MinWidth="600" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- Заголовки секций (локальный стиль, только для этого окна) -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- ========== Шапка окна ========== -->
        <Border Grid.Row="0" Background="#1976D2">
            <StackPanel Orientation="Horizontal" Margin="20,0">
                <TextBlock Text="📝" FontSize="24" Foreground="White"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="{Binding WindowTitle}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
        <!-- ========== Контент с прокруткой ========== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <!-- ========== ОСНОВНЫЕ ДАННЫЕ ========== -->
                <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📋 Основные данные" Style="{StaticResource SectionHeader}"/>
                        <!-- Название задачи -->
                        <TextBlock Text="Название *" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding Название, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBox}"/>
                        <!-- Сложность с ползунком и кнопками +/- -->
                        <TextBlock Text="Сложность" Style="{StaticResource FormLabel}"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Content="−"
                                    Command="{Binding DecreaseDifficultyCommand}"
                                    Background="#E0E0E0"
                                    Foreground="#212121"
                                    FontSize="18" FontWeight="Bold"
                                    Height="36"
                                    Style="{StaticResource ActionButton}"/>
                            <Slider Grid.Column="1"
                                    Value="{Binding Сложность}"
                                    Minimum="1" Maximum="10"
                                    IsSnapToTickEnabled="True"
                                    TickFrequency="1"
                                    Margin="8,0"
                                    VerticalAlignment="Center"/>
                            <Button Grid.Column="2"
                                    Content="+"
                                    Command="{Binding IncreaseDifficultyCommand}"
                                    Background="#E0E0E0"
                                    Foreground="#212121"
                                    FontSize="18" FontWeight="Bold"
                                    Height="36"
                                    Style="{StaticResource ActionButton}"/>
                            <!-- Текстовое отображение сложности (😊 Очень лёгкая) -->
                            <Border Grid.Column="3"
                                    Background="#E3F2FD"
                                    CornerRadius="4"
                                    Padding="8,4"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding СложностьТекст}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#1565C0"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </Border>
                        </Grid>
                        <!-- Краткое условие (многострочное) -->
                        <TextBlock Text="Краткое условие" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding КраткоеУсловие, UpdateSourceTrigger=PropertyChanged}"
                                 Height="70" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalContentAlignment="Top" Padding="10,8"
                                 Background="White" Foreground="#212121"
                                 BorderBrush="#E0E0E0" BorderThickness="1"
                                 Margin="0,0,0,12"/>
                        <!-- Идея решения (многострочное) -->
                        <TextBlock Text="Идея решения" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding ИдеяРешения, UpdateSourceTrigger=PropertyChanged}"
                                 Height="70" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalContentAlignment="Top" Padding="10,8"
                                 Background="White" Foreground="#212121"
                                 BorderBrush="#E0E0E0" BorderThickness="1"
                                 Margin="0,0,0,12"/>
                        <!-- Ссылка на Polygon -->
                        <TextBlock Text="Ссылка на Polygon" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding СсылкаPolygon, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBox}"/>
                        <!-- Примечание (многострочное) -->
                        <TextBlock Text="Примечание" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding Примечание, UpdateSourceTrigger=PropertyChanged}"
                                 Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalContentAlignment="Top" Padding="10,8"
                                 Background="White" Foreground="#212121"
                                 BorderBrush="#E0E0E0" BorderThickness="1"
                                 Margin="0"/>
                    </StackPanel>
                </Border>
                <!-- ========== ТЕГИ (чекбоксы с визуальными кнопками) ========== -->
                <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="🏷️ Теги" Style="{StaticResource SectionHeader}"/>
                        <!-- Список тегов с чекбоксами -->
                        <ItemsControl ItemsSource="{Binding Tags}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,8,8">
                                        <CheckBox IsChecked="{Binding IsSelected}" Cursor="Hand">
                                            <Border CornerRadius="12" Padding="10,4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F5F5F5"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="#E3F2FD"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Tag.Название}" FontSize="13">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#666666"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Foreground" Value="#1565C0"/>
                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <CheckBox.Template>
                                                <ControlTemplate TargetType="CheckBox">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </CheckBox.Template>
                                        </CheckBox>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Заглушка если нет тегов -->
                        <TextBlock Text="Нет доступных тегов"
                                   FontSize="13" Foreground="#9E9E9E">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Tags.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <!-- ========== ПЛАТФОРМЫ (с флагом готовности) ========== -->
                <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="💻 Платформы" Style="{StaticResource SectionHeader}"/>
                        <!-- Список платформ с чекбоксами и готовностью -->
                        <ItemsControl ItemsSource="{Binding Platforms}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="12,8" CornerRadius="6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F5F5F5"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Чекбокс выбора платформы -->
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,10,0"/>
                                            <!-- Название и описание -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Platform.Название}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#212121"/>
                                                <TextBlock Text="{Binding Platform.АвтопроверкаТекст}"
                                                           FontSize="11" Foreground="#9E9E9E"/>
                                            </StackPanel>
                                            <!-- Чекбокс готовности (только для выбранных) -->
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="Готово:"
                                                           FontSize="12" Foreground="#555555"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,6,0"/>
                                                <CheckBox IsChecked="{Binding Готовность}"
                                                          VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <!-- ========== КОНТЕСТЫ (чекбоксы с визуальными кнопками) ========== -->
                <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="🏆 Контесты" Style="{StaticResource SectionHeader}"/>
                        <!-- Список контестов с чекбоксами -->
                        <ItemsControl ItemsSource="{Binding Contests}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,8,8">
                                        <CheckBox IsChecked="{Binding IsSelected}" Cursor="Hand">
                                            <Border CornerRadius="6" Padding="10,6">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F5F5F5"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="#FFF8E1"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Contest.Название}" FontSize="13">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#666666"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Foreground" Value="#E65100"/>
                                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Contest.Год_создания}"
                                                               FontSize="11" Foreground="#9E9E9E"/>
                                                </StackPanel>
                                            </Border>
                                            <CheckBox.Template>
                                                <ControlTemplate TargetType="CheckBox">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </CheckBox.Template>
                                        </CheckBox>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <!-- ========== Кнопки Сохранить/Отмена ========== -->
        <Border Grid.Row="2" Background="White" Padding="20,12">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="10" ShadowDepth="-2"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Индикатор загрузки -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <ProgressBar Width="120" Height="4" IsIndeterminate="True" Margin="0,0,8,0"/>
                    <TextBlock Text="Загрузка..." FontSize="12" Foreground="#9E9E9E"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <!-- Кнопка Отмена -->
                <Button Grid.Column="1"
                        Content="✖ Отмена"
                        Command="{Binding CancelCommand}"
                        Background="#9E9E9E"
                        Width="110"
                        Style="{StaticResource ActionButton}"
                        Margin="0,0,8,0"/>
                <!-- Кнопка Сохранить/Создать -->
                <Button Grid.Column="2"
                        Content="{Binding SaveButtonText}"
                        Command="{Binding SaveCommand}"
                        Background="#2196F3"
                        Width="120"
                        Style="{StaticResource ActionButton}"/>
            </Grid>
        </Border>
    </Grid>
</Window>