<UserControl x:Class="BDP_MVVM.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:BDP_MVVM.Views.Converters"
             Background="#F5F5F5">
    <UserControl.Resources>
        <!-- Конвертеры для видимости элементов -->
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:NotNullToVisibilityConverter x:Key="NotNullToVis"/>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- ========== ЛЕВАЯ ПАНЕЛЬ: список пользователей ========== -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- Заголовок с иконкой и счётчиком -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="👥" FontSize="28" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Пользователи"
                               FontSize="22" FontWeight="Bold" Foreground="#212121"/>
                    <TextBlock Text="{Binding Users.Count, StringFormat='Всего: {0}'}"
                               FontSize="13" Foreground="#666666"/>
                </StackPanel>
            </StackPanel>
            <!-- Кнопка создания нового пользователя -->
            <Button Grid.Row="1"
                    Content="➕ Новый пользователь"
                    Command="{Binding ShowCreateCommand}"
                    Background="#4CAF50"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource ActionButton}"
                    Margin="0,0,0,16"/>
            <!-- Список пользователей -->
            <Border Grid.Row="2" Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <Grid>
                    <!-- Заглушка пустого списка -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding HasUsers, Converter={StaticResource InverseBoolToVis}}">
                        <TextBlock Text="👥" FontSize="48" HorizontalAlignment="Center" Opacity="0.3"/>
                        <TextBlock Text="Нет пользователей" FontSize="16"
                                   Foreground="#9E9E9E"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                    <!-- ListView пользователей -->
                    <ListView ItemsSource="{Binding Users}"
                              SelectedItem="{Binding SelectedUser}"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="8">
                        <!-- Стиль элемента списка с подсветкой -->
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,4"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="bg" Background="Transparent"
                                                    CornerRadius="6" Padding="12,10">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#E3F2FD"/>
                                                    <Setter TargetName="bg" Property="BorderBrush" Value="#2196F3"/>
                                                    <Setter TargetName="bg" Property="BorderThickness" Value="1"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#F5F5F5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <!-- Шаблон элемента: аватар, логин/роль, дата -->
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Аватар (иконка пользователя) -->
                                    <Border Grid.Column="0"
                                            Width="32" Height="32"
                                            CornerRadius="16"
                                            Background="#E3F2FD">
                                        <TextBlock Text="👤" FontSize="16"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- Логин и название роли -->
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Логин}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#212121"/>
                                        <TextBlock Text="{Binding РольНазвание}"
                                                   FontSize="12" Foreground="#9E9E9E"/>
                                    </StackPanel>
                                    <!-- Дата регистрации -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding ДатаФорматированная}"
                                               FontSize="11" Foreground="#BDBDBD"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <!-- Индикатор загрузки -->
                    <Border Background="#EEFFFFFF"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ProgressBar Width="150" Height="4"
                                         IsIndeterminate="True" Margin="0,0,0,8"/>
                            <TextBlock Text="Загрузка..."
                                       Foreground="#666666" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        <!-- ========== ПРАВАЯ ПАНЕЛЬ: создание/редактирование пользователя ========== -->
        <Grid Grid.Column="1">
            <!-- Заглушка когда ничего не выбрано и не создаётся -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding SelectedUser}" Value="{x:Null}"/>
                                    <Condition Binding="{Binding IsCreating}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="👈" FontSize="64" HorizontalAlignment="Center" Opacity="0.3"/>
                <TextBlock Text="Выберите пользователя или создайте нового"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="#9E9E9E"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
            <!-- ========== ФОРМА СОЗДАНИЯ НОВОГО ПОЛЬЗОВАТЕЛЯ ========== -->
            <Border Background="White" CornerRadius="8" Padding="24"
                    VerticalAlignment="Top"
                    Visibility="{Binding IsCreating, Converter={StaticResource BoolToVis}}">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="➕ Новый пользователь"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#212121" Margin="0,0,0,20"/>
                    <!-- Логин -->
                    <TextBlock Text="Логин *" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding NewЛогин, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}"/>
                    <!-- Пароль (PasswordBox не поддерживает биндинг) -->
                    <TextBlock Text="Пароль *" Style="{StaticResource FormLabel}"/>
                    <PasswordBox x:Name="NewPasswordBox"
                                 Height="36" Padding="10,0"
                                 FontSize="13"
                                 Background="White"
                                 BorderBrush="#E0E0E0"
                                 BorderThickness="1"
                                 Margin="0,0,0,12"/>
                    <!-- Email -->
                    <TextBlock Text="Email" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding NewEmail, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}"/>
                    <!-- Описание (многострочное) -->
                    <TextBlock Text="Описание" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding NewОписание, UpdateSourceTrigger=PropertyChanged}"
                             Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalContentAlignment="Top" Padding="10,8"
                             Background="White" Foreground="#212121"
                             BorderBrush="#E0E0E0" BorderThickness="1"
                             Margin="0,0,0,12"/>
                    <!-- Выбор роли -->
                    <TextBlock Text="Роль *" Style="{StaticResource FormLabel}"/>
                    <ComboBox ItemsSource="{Binding Roles}"
                              SelectedItem="{Binding NewРоль}"
                              DisplayMemberPath="Название"
                              Height="36" FontSize="13"
                              Margin="0,0,0,20"/>
                    <!-- Кнопки отмены и создания -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="✖ Отмена"
                                Command="{Binding CancelCommand}"
                                Background="#9E9E9E"
                                Style="{StaticResource ActionButton}"/>
                        <Button Content="➕ Создать"
                                Command="{Binding CreateCommand}"
                                Background="#4CAF50"
                                Style="{StaticResource ActionButton}"
                                Margin="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <!-- ========== ДЕТАЛИ ВЫБРАННОГО ПОЛЬЗОВАТЕЛЯ ========== -->
            <Border Background="White" CornerRadius="8" Padding="24"
                    VerticalAlignment="Top"
                    Visibility="{Binding SelectedUser, Converter={StaticResource NotNullToVis}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <!-- Скрываем если открыта форма создания -->
                            <DataTrigger Binding="{Binding IsCreating}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedUser}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Аватар, логин и роль -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Border Width="56" Height="56" CornerRadius="28"
                                Background="#E3F2FD" Margin="0,0,16,0">
                            <TextBlock Text="👤" FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedUser.Логин}"
                                       FontSize="20" FontWeight="Bold" Foreground="#212121"/>
                            <TextBlock Text="{Binding SelectedUser.РольНазвание}"
                                       FontSize="13" Foreground="#666666"/>
                            <TextBlock Text="{Binding SelectedUser.ДатаФорматированная, StringFormat='Создан: {0}'}"
                                       FontSize="12" Foreground="#9E9E9E"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Карточка с основной информацией -->
                    <Border Background="#F5F5F5" CornerRadius="8"
                            Padding="16" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Margin="0,0,30,0">
                                <TextBlock Text="ID" FontSize="12" Foreground="#9E9E9E"/>
                                <TextBlock Text="{Binding SelectedUser.User_ID, StringFormat='#{0}'}"
                                           FontSize="20" FontWeight="Bold" Foreground="#2196F3"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,30,0">
                                <TextBlock Text="Email" FontSize="12" Foreground="#9E9E9E"/>
                                <TextBlock Text="{Binding SelectedUser.Email}"
                                           FontSize="14" Foreground="#212121"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <!-- Карточка с правами роли -->
                    <Border Background="#F5F5F5" CornerRadius="8"
                            Padding="16" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="🔐 Права роли"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#555555" Margin="0,0,0,10"/>
                            <!-- Право редактировать задачи -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock FontSize="13">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="✅"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedUser.Роль.Может_редактировать_задачи}" Value="False">
                                                    <Setter Property="Text" Value="❌"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text=" Редактировать задачи"
                                           FontSize="13" Foreground="#555555"/>
                            </StackPanel>
                            <!-- Право удалять задачи -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock FontSize="13">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="✅"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedUser.Роль.Может_удалять_задачи}" Value="False">
                                                    <Setter Property="Text" Value="❌"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text=" Удалять задачи"
                                           FontSize="13" Foreground="#555555"/>
                            </StackPanel>
                            <!-- Право управлять пользователями -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="13">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="✅"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedUser.Роль.Может_управлять_пользователями}" Value="False">
                                                    <Setter Property="Text" Value="❌"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text=" Управлять пользователями"
                                           FontSize="13" Foreground="#555555"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <!-- Форма редактирования (показывается при нажатии "Редактировать") -->
                    <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Логин *" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding EditЛогин, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" Height="36" Padding="10,0"
                                 VerticalContentAlignment="Center"
                                 Background="White" Foreground="#212121"
                                 BorderBrush="#2196F3" BorderThickness="2"
                                 Margin="0,0,0,12"/>
                        <TextBlock Text="Email" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding EditEmail, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" Height="36" Padding="10,0"
                                 VerticalContentAlignment="Center"
                                 Background="White" Foreground="#212121"
                                 BorderBrush="#2196F3" BorderThickness="2"
                                 Margin="0,0,0,12"/>
                        <TextBlock Text="Описание" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding EditОписание, UpdateSourceTrigger=PropertyChanged}"
                                 Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalContentAlignment="Top" Padding="10,8"
                                 Background="White" Foreground="#212121"
                                 BorderBrush="#2196F3" BorderThickness="2"
                                 Margin="0,0,0,12"/>
                        <TextBlock Text="Роль *" Style="{StaticResource FormLabel}"/>
                        <ComboBox ItemsSource="{Binding Roles}"
                                  SelectedItem="{Binding EditРоль}"
                                  DisplayMemberPath="Название"
                                  Height="36" FontSize="13"
                                  Margin="0,0,0,12"/>
                        <!-- Пароль (опционально, только если хотим изменить) -->
                        <TextBlock Text="Новый пароль (оставьте пустым чтобы не менять)"
                                   Style="{StaticResource FormLabel}"/>
                        <PasswordBox x:Name="EditPasswordBox"
                                     FontSize="13" Height="36" Padding="10,0"
                                     Background="White"
                                     BorderBrush="#2196F3" BorderThickness="2"
                                     Margin="0,0,0,16"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾 Сохранить"
                                    Command="{Binding SaveEditCommand}"
                                    Background="#4CAF50"
                                    Style="{StaticResource ActionButton}"/>
                            <Button Content="✖ Отмена"
                                    Command="{Binding CancelCommand}"
                                    Background="#9E9E9E"
                                    Style="{StaticResource ActionButton}" Margin="0"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Кнопки действий (показываются когда не в режиме редактирования) -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
                        <Button Content="✏️ Редактировать"
                                Command="{Binding EditCommand}"
                                Background="#2196F3"
                                Style="{StaticResource ActionButton}"/>
                        <Button Content="🗑️ Удалить"
                                Command="{Binding DeleteCommand}"
                                Background="#F44336"
                                Style="{StaticResource ActionButton}" Margin="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>