<UserControl x:Class="BDP_MVVM.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:BDP_MVVM.Views.Converters"
             Background="#F5F5F5">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- Стиль карточки статистики (локальный, только для Reports) -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.08"
                                      BlurRadius="10" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <!-- Индикатор загрузки (поверх всего контента) -->
        <Border Background="#EEFFFFFF" Panel.ZIndex="10"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar Width="200" Height="4" IsIndeterminate="True" Margin="0,0,0,10"/>
                <TextBlock Text="Загрузка отчёта..." FontSize="16"
                           Foreground="#666666" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <!-- ========== Заголовок страницы и кнопки действий ========== -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Заголовок с иконкой -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="📊" FontSize="28" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Отчёты и аналитика"
                                       FontSize="22" FontWeight="Bold" Foreground="#212121"/>
                            <TextBlock Text="Статистика по задачам, тегам и контестам"
                                       FontSize="13" Foreground="#666666"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Кнопки обновления и экспорта -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="🔄 Обновить"
                                Command="{Binding LoadCommand}"
                                Background="#607D8B"
                                Style="{StaticResource ActionButton}"
                                Margin="0,0,10,0"/>
                        <Button Content="📥 Экспорт в CSV"
                                Command="{Binding ExportTasksCsvCommand}"
                                Background="#4CAF50"
                                Style="{StaticResource ActionButton}"
                                Margin="0"/>
                    </StackPanel>
                </Grid>
                <!-- ========== Карточки статистики (5 метрик) ========== -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Всего задач -->
                    <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="📋" FontSize="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalTasks}"
                                       FontSize="36" FontWeight="Bold"
                                       Foreground="#2196F3"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Всего задач"
                                       FontSize="13" Foreground="#666666"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <!-- Готовые задачи с процентом -->
                    <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="✅" FontSize="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ReadyTasks}"
                                       FontSize="36" FontWeight="Bold"
                                       Foreground="#4CAF50"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ReadyTasksPercent, StringFormat='Готовы ({0})'}"
                                       FontSize="13" Foreground="#666666"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <!-- Средняя сложность -->
                    <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="⭐" FontSize="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding AvgDifficultyText}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="#FF9800"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Средняя сложность"
                                       FontSize="13" Foreground="#666666"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <!-- Количество тегов -->
                    <Border Grid.Column="3" Style="{StaticResource StatCard}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="🏷️" FontSize="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalTags}"
                                       FontSize="36" FontWeight="Bold"
                                       Foreground="#9C27B0"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Тегов"
                                       FontSize="13" Foreground="#666666"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <!-- Количество контестов -->
                    <Border Grid.Column="4" Style="{StaticResource StatCard}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="🏆" FontSize="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalContests}"
                                       FontSize="36" FontWeight="Bold"
                                       Foreground="#F44336"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Контестов"
                                       FontSize="13" Foreground="#666666"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
                <!-- ========== Диаграмма распределения по уровням сложности ========== -->
                <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>

                    <StackPanel>
                        <TextBlock Text="📊 Распределение задач по сложности"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="#212121" Margin="0,0,0,16"/>
                        <!-- Список диапазонов сложности с прогресс-барами -->
                        <ItemsControl ItemsSource="{Binding DifficultyGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Название диапазона (😊 Лёгкие 1-2) -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Название}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>
                                        <!-- Прогресс-бар с цветом по диапазону -->
                                        <Border Grid.Column="1" Margin="10,0"
                                                Background="#F5F5F5"
                                                CornerRadius="4" Height="22">
                                            <ProgressBar Value="{Binding Процент}"
                                                         Minimum="0" Maximum="100"
                                                         Height="22"
                                                         Background="Transparent"
                                                         BorderThickness="0">
                                                <ProgressBar.Style>
                                                    <Style TargetType="ProgressBar">
                                                        <Setter Property="Foreground" Value="#8BC34A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Диапазон}" Value="3-4">
                                                                <Setter Property="Foreground" Value="#FFC107"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Диапазон}" Value="5-6">
                                                                <Setter Property="Foreground" Value="#FF9800"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Диапазон}" Value="7-8">
                                                                <Setter Property="Foreground" Value="#F44336"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Диапазон}" Value="9-10">
                                                                <Setter Property="Foreground" Value="#9C27B0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ProgressBar.Style>
                                            </ProgressBar>
                                        </Border>
                                        <!-- Процент (45.2%) -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding ПроцентТекст}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#212121"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                        <!-- Количество задач (23) -->
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Количество}"
                                                   FontSize="13" Foreground="#9E9E9E"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <!-- ========== Таблица всех задач ========== -->
                <Border Background="White" CornerRadius="8" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📋 Все задачи"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="#212121" Margin="0,0,0,16"/>
                        <!-- DataGrid со списком задач -->
                        <DataGrid ItemsSource="{Binding Tasks}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#F0F0F0"
                                  Background="White"
                                  BorderThickness="0"
                                  RowHeight="42"
                                  HeadersVisibility="Column"
                                  CanUserResizeRows="False">
                            <!-- Стиль заголовков столбцов -->
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F5F5F5"/>
                                    <Setter Property="Foreground" Value="#555555"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <!-- Столбцы таблицы -->
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID"
                                                    Binding="{Binding Task_ID, StringFormat='#{0}'}"
                                                    Width="60"/>
                                <DataGridTextColumn Header="Название"
                                                    Binding="{Binding Название}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="Сложность"
                                                    Binding="{Binding Сложность}"
                                                    Width="90"/>
                                <DataGridTextColumn Header="Автор"
                                                    Binding="{Binding Автор.Логин}"
                                                    Width="120"/>
                                <DataGridTextColumn Header="Дата"
                                                    Binding="{Binding ДатаСозданияФорматированная}"
                                                    Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>