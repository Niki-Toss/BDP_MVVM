<Window x:Class="BDP_MVVM.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:BDP_MVVM.Views.Converters"
        Title="Банк задач по программированию" 
        Height="720" 
        Width="1200"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- Стиль пункта меню (базовый, неактивный) -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B3E5FC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0"
                                BorderBrush="Transparent">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Подсветка при наведении -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1565C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>
        <!-- ========== ШАПКА: логотип, название раздела, пользователь ========== -->
        <Border Grid.Row="0" Background="#1976D2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Логотип и аббревиатура -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="16,0">
                    <TextBlock Text="📚" FontSize="28" Margin="0,0,10,0"/>
                    <TextBlock Text="БЗП"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <!-- Название текущего раздела -->
                <TextBlock Grid.Column="1"
                           Text="{Binding CurrentPageTitle}"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="10,0"/>
                <!-- Информация о пользователе и кнопка выхода -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0">
                    <!-- Карточка пользователя -->
                    <Border Background="#1565C0"
                            CornerRadius="4"
                            Padding="12,6"
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤 " Foreground="White" FontSize="13"/>
                            <TextBlock Text="{Binding CurrentUserName}"
                                       Foreground="White"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text=" · " Foreground="#90CAF9" FontSize="13"/>
                            <TextBlock Text="{Binding CurrentUserRole}"
                                       Foreground="#90CAF9"
                                       FontSize="13"/>
                        </StackPanel>
                    </Border>
                    <!-- Кнопка выхода -->
                    <Button Content="🚪 Выход"
                            Command="{Binding LogoutCommand}"
                            Background="#F44336"
                            Foreground="White"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            Padding="14,6"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D32F2F"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        <!-- ========== ОСНОВНАЯ ОБЛАСТЬ: меню + контент ========== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- ========== БОКОВОЕ МЕНЮ ========== -->
            <Border Grid.Column="0" Background="#1E88E5">
                <StackPanel>
                    <!-- Секция: Задачи -->
                    <TextBlock Text="ЗАДАЧИ"
                               Foreground="#90CAF9"
                               FontSize="11"
                               FontWeight="Bold"
                               Margin="16,20,0,6"/>
                    <Button Content="📋  Список задач"
                            Command="{Binding NavigateToTasksCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <!-- Подсветка активной страницы -->
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Tasks">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Background" Value="#1565C0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Border Height="1" Background="#1565C0" Margin="16,10"/>
                    <!-- Секция: Справочники -->
                    <TextBlock Text="СПРАВОЧНИКИ"
                               Foreground="#90CAF9"
                               FontSize="11"
                               FontWeight="Bold"
                               Margin="16,6,0,6"/>
                    <Button Content="🏷️  Теги"
                            Command="{Binding NavigateToTagsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Tags">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Background" Value="#1565C0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="🏆  Контесты"
                            Command="{Binding NavigateToContestsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Contests">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Background" Value="#1565C0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="💻  Платформы"
                            Command="{Binding NavigateToPlatformsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Platforms">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Background" Value="#1565C0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Border Height="1" Background="#1565C0" Margin="16,10"/>
                    <!-- Секция: Администрирование (только для админов) -->
                    <TextBlock Text="АДМИНИСТРИРОВАНИЕ"
                               Foreground="#90CAF9"
                               FontSize="11"
                               FontWeight="Bold"
                               Margin="16,6,0,6"/>
                    <!-- Обёртка для показа Tooltip на неактивной кнопке -->
                    <Border Background="Transparent">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <!-- Если нет прав - показываем курсор "запрещено" и Tooltip -->
                                    <DataTrigger Binding="{Binding CanManageUsers}" Value="False">
                                        <Setter Property="Cursor" Value="No"/>
                                        <Setter Property="ToolTip">
                                            <Setter.Value>
                                                <ToolTip Background="#424242" BorderBrush="#616161" BorderThickness="1" Padding="12,10">
                                                    <StackPanel MaxWidth="280">
                                                        <TextBlock Text="🔒 Доступ ограничен" 
                                                                   FontWeight="Bold" FontSize="13"
                                                                   Foreground="White"
                                                                   Margin="0,0,0,6"/>
                                                        <TextBlock Text="Раздел доступен только администраторам и пользователям с правами на управление учётными записями."
                                                                   TextWrapping="Wrap" FontSize="12"
                                                                   Foreground="#E0E0E0"
                                                                   LineHeight="17"/>
                                                    </StackPanel>
                                                </ToolTip>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button Content="👥  Пользователи"
                                Command="{Binding NavigateToUsersCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Users">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Background" Value="#1565C0"/>
                                        </DataTrigger>
                                        <!-- Блокируем кнопку если нет прав -->
                                        <DataTrigger Binding="{Binding CanManageUsers}" Value="False">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Border>
                    <Border Height="1" Background="#1565C0" Margin="16,10"/>
                    <!-- Секция: Аналитика -->
                    <TextBlock Text="АНАЛИТИКА"
                               Foreground="#90CAF9"
                               FontSize="11"
                               FontWeight="Bold"
                               Margin="16,6,0,6"/>
                    <Button Content="📊  Отчёты"
                            Command="{Binding NavigateToReportsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Reports">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Background" Value="#1565C0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <!-- Версия приложения -->
                    <TextBlock Text="v1.0.0"
                               Foreground="#64B5F6"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,30,0,0"/>
                </StackPanel>
            </Border>
            <!-- ========== КОНТЕНТ (сюда загружаются страницы) ========== -->
            <Border Grid.Column="1" Background="#F5F5F5">
                <ContentControl x:Name="MainContent"/>
            </Border>
        </Grid>
        <!-- ========== СТАТУС БАР ========== -->
        <Border Grid.Row="2" Background="#1565C0">
            <Grid Margin="10,0">
                <!-- Copyright -->
                <TextBlock Text="© 2026 Банк задач по программированию"
                           Foreground="#90CAF9"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <!-- Статус (название страницы + время) -->
                <TextBlock Text="{Binding StatusText}"
                           Foreground="White"
                           FontSize="11"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>